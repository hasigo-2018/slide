<!-- スライド1: 表紙 -->
<div class="slide-container full-bg-image active">
    <div class="content-overlay">
        <h1>AI生成素材のUI統合と<br>画像最適化<span>【理論編】</span></h1>
        <p>軽くて綺麗。最後の技術工程</p>
    </div>
</div>

<!-- スライド2: 今日の位置づけ -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">今日の位置づけ：3つの品質を揃えて渡す</h2>
    <div class="content-block">
        <p>026〜027で作った画像は「デザイン品質」は完成している。しかし、エンジニアに渡せる状態にするには、あと2つの品質が必要だ。</p>
        <div class="two-column tiled">
            <div>
                <h3>完成していること</h3>
                <ul>
                    <li>🎨 <strong>デザイン品質</strong>：026で背景除去・補正済み、027でバナー制作済み</li>
                    <li>見た目はプロクオリティ。Figma上での見栄えは問題なし</li>
                </ul>
            </div>
            <div>
                <h3>これから整えること</h3>
                <ul>
                    <li>⚡ <strong>パフォーマンス品質</strong>：ファイルサイズ・フォーマット・解像度の最適化</li>
                    <li>📁 <strong>管理品質</strong>：命名規則・フォルダ構成の統一（039ハンドオフへの布石）</li>
                </ul>
            </div>
        </div>
        <div class="highlight-box">💡 今日の判断軸は「軽ければよい」ではない。画質・表示速度・管理しやすさのトレードオフを、画像の配置目的ごとに判断する</div>
    </div>
</div>

<!-- スライド3: 画像最適化の3つの軸 -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">画像最適化の3つの軸</h2>
    <div class="content-block">
        <div class="content-block svg-centered">
            <svg viewBox="0 0 900 340" xmlns="http://www.w3.org/2000/svg" style="max-width:900px;width:100%;">
                <!-- 背景カード: フォーマット -->
                <rect x="20" y="20" width="260" height="300" rx="16" fill="white" fill-opacity="0.08"/>
                <text x="150" y="62" text-anchor="middle" fill="#00d4ff" font-size="28" font-weight="bold">📄 フォーマット</text>
                <line x1="50" y1="78" x2="250" y2="78" stroke="#00d4ff" stroke-opacity="0.3" stroke-width="1"/>
                <text x="150" y="110" text-anchor="middle" fill="white" font-size="20" font-weight="bold">WebP ＞ JPEG ＞ PNG</text>
                <text x="150" y="142" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">同品質でWebPはJPEGより</text>
                <text x="150" y="166" text-anchor="middle" fill="#00d4ff" font-size="22" font-weight="bold">約30%軽量</text>
                <text x="150" y="198" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">透過が必要 → WebP / PNG</text>
                <text x="150" y="224" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">写真・グラデーション → JPEG</text>
                <text x="150" y="250" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">主要ブラウザはWebPを</text>
                <text x="150" y="272" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">ほぼすべてサポート済み</text>

                <!-- 背景カード: 圧縮率 -->
                <rect x="320" y="20" width="260" height="300" rx="16" fill="white" fill-opacity="0.08"/>
                <text x="450" y="62" text-anchor="middle" fill="#00d4ff" font-size="28" font-weight="bold">🗜️ 圧縮率</text>
                <line x1="350" y1="78" x2="550" y2="78" stroke="#00d4ff" stroke-opacity="0.3" stroke-width="1"/>
                <text x="450" y="110" text-anchor="middle" fill="white" font-size="20" font-weight="bold">品質80%がスイートスポット</text>
                <text x="450" y="150" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">100%　→　無劣化・サイズ大</text>
                <rect x="340" y="162" width="220" height="34" rx="6" fill="#00d4ff" fill-opacity="0.18"/>
                <text x="450" y="184" text-anchor="middle" fill="#00d4ff" font-size="20" font-weight="bold">80%　→　劣化なし・大幅削減 ✅</text>
                <text x="450" y="220" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">70%以下 → 劣化が目視で確認</text>
                <text x="450" y="248" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">できるため非推奨</text>
                <text x="450" y="285" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="16">まず仮説を立て、検証する</text>

                <!-- 背景カード: 解像度 -->
                <rect x="620" y="20" width="260" height="300" rx="16" fill="white" fill-opacity="0.08"/>
                <text x="750" y="62" text-anchor="middle" fill="#00d4ff" font-size="28" font-weight="bold">📐 解像度</text>
                <line x1="650" y1="78" x2="850" y2="78" stroke="#00d4ff" stroke-opacity="0.3" stroke-width="1"/>
                <text x="750" y="108" text-anchor="middle" fill="white" font-size="20" font-weight="bold">LP用の上限サイズ</text>
                <text x="750" y="138" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="18">PC　幅 1440px</text>
                <text x="750" y="164" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="18">SP　幅 750px</text>
                <text x="750" y="196" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">Retina対応なら2倍書き出し</text>
                <text x="750" y="220" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="17">（PC 2880px / SP 1500px）</text>
                <text x="750" y="252" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="16">上限超えは無駄に重い。</text>
                <text x="750" y="274" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="16">サイズとのトレードオフで判断</text>
            </svg>
        </div>
        <div class="highlight-box">⚠️ この3軸は独立していない。フォーマット × 圧縮率 × 解像度の組み合わせで最終ファイルサイズが決まる。FV画像200KB以下を目安に、3軸を調整する</div>
    </div>
</div>

<!-- スライド4: Squooshの使い方 -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">Squoosh：2段階ワークフロー</h2>
    <div class="content-block">
        <p>Google製の無料WebP変換・圧縮ツール（squoosh.app）。ブラウザ上で動作し、インストール不要。Figmaから書き出したPNG/JPEGをWebPに変換するのが標準フローだ。</p>
        <div class="content-block svg-centered">
            <svg viewBox="0 0 860 180" xmlns="http://www.w3.org/2000/svg" style="max-width:860px;width:100%;">
                <!-- Step 1 -->
                <rect x="10" y="20" width="155" height="140" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="87" y="55" text-anchor="middle" fill="#00d4ff" font-size="26">🎨</text>
                <text x="87" y="82" text-anchor="middle" fill="white" font-size="18" font-weight="bold">Step 1</text>
                <text x="87" y="106" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">Figmaから</text>
                <text x="87" y="127" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">PNG / JPEG</text>
                <text x="87" y="148" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">で書き出す</text>
                <!-- 矢印 -->
                <polygon points="175,90 195,80 195,100" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="165" y1="90" x2="195" y2="90" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- Step 2 -->
                <rect x="200" y="20" width="155" height="140" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="277" y="55" text-anchor="middle" fill="#00d4ff" font-size="26">📂</text>
                <text x="277" y="82" text-anchor="middle" fill="white" font-size="18" font-weight="bold">Step 2</text>
                <text x="277" y="106" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">Squooshに</text>
                <text x="277" y="127" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">ドラッグ＆</text>
                <text x="277" y="148" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">ドロップ</text>
                <!-- 矢印 -->
                <polygon points="365,90 385,80 385,100" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="355" y1="90" x2="385" y2="90" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- Step 3 -->
                <rect x="390" y="20" width="155" height="140" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="467" y="55" text-anchor="middle" fill="#00d4ff" font-size="26">⚙️</text>
                <text x="467" y="82" text-anchor="middle" fill="white" font-size="18" font-weight="bold">Step 3</text>
                <text x="467" y="106" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">フォーマット</text>
                <text x="467" y="127" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">→ WebP</text>
                <text x="467" y="148" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">品質 80% に設定</text>
                <!-- 矢印 -->
                <polygon points="555,90 575,80 575,100" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="545" y1="90" x2="575" y2="90" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- Step 4 -->
                <rect x="580" y="20" width="155" height="140" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="657" y="55" text-anchor="middle" fill="#00d4ff" font-size="26">🔍</text>
                <text x="657" y="82" text-anchor="middle" fill="white" font-size="18" font-weight="bold">Step 4</text>
                <text x="657" y="106" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">Before/After</text>
                <text x="657" y="127" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">スライダーで</text>
                <text x="657" y="148" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">画質を確認</text>
                <!-- 矢印 -->
                <polygon points="745,90 765,80 765,100" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="735" y1="90" x2="765" y2="90" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- Step 5 -->
                <rect x="770" y="20" width="80" height="140" rx="12" fill="#00d4ff" fill-opacity="0.18"/>
                <text x="810" y="55" text-anchor="middle" fill="#00d4ff" font-size="26">⬇️</text>
                <text x="810" y="82" text-anchor="middle" fill="white" font-size="18" font-weight="bold">Step 5</text>
                <text x="810" y="110" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">DL</text>
                <text x="810" y="132" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">.webp</text>
                <text x="810" y="154" text-anchor="middle" fill="white" fill-opacity="0.8" font-size="15">保存</text>
            </svg>
        </div>
        <p class="text-sub">Squooshは左右のスライダーを動かすだけでBefore（元画像）とAfter（変換後）の画質を直接比較できる。目視で「これは使える」と判断したら即ダウンロード。</p>
    </div>
</div>

<!-- スライド5: Figmaの書き出し設定の標準化 -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">Figmaの書き出し設定：標準化ルール</h2>
    <div class="content-block">
        <p>書き出し設定を毎回バラバラに行うと、エンジニアへの引き渡し時に「どのファイルがどこで使われるか」が不明になる。標準化こそが管理品質の核心だ。</p>
        <div class="two-column tiled">
            <div>
                <h3>書き出し設定のルール</h3>
                <ul>
                    <li>📄 <strong>フォーマット</strong>：PNG（Squooshで変換前提）/ JPEG（写真系はそのまま）</li>
                    <li>🔢 <strong>倍率</strong>：1x（標準）＋ 2x（Retina対応）の2パターン</li>
                    <li>🏷️ <strong>命名規則</strong>：「セクション名_用途_幅.拡張子」</li>
                </ul>
                <p class="text-note">例：fv_main_1440.webp　/ trust_case01_600.webp　/ banner_fb_1200.webp</p>
            </div>
            <div>
                <h3>フォルダ構成（引き渡し時の構造）</h3>
                <div class="content-block svg-centered">
                    <svg viewBox="0 0 340 200" xmlns="http://www.w3.org/2000/svg" style="max-width:340px;width:100%;">
                        <text x="20" y="30" fill="white" font-size="19" font-weight="bold">📁 images/</text>
                        <text x="50" y="65" fill="#00d4ff" font-size="17">📂 lp/</text>
                        <text x="80" y="88" fill="white" fill-opacity="0.7" font-size="15">fv_main_1440.webp</text>
                        <text x="80" y="110" fill="white" fill-opacity="0.7" font-size="15">section02_case01_600.webp …</text>
                        <text x="50" y="140" fill="#00d4ff" font-size="17">📂 banner/</text>
                        <text x="80" y="163" fill="white" fill-opacity="0.7" font-size="15">banner_fb_1200.webp …</text>
                        <text x="50" y="193" fill="#00d4ff" font-size="17">📂 common/</text>
                    </svg>
                </div>
            </div>
        </div>
        <div class="highlight-box">📌 この命名規則とフォルダ構成はBlock 7（039・エンジニアへのハンドオフ）でそのまま使用する。今から習慣にしておくことで、引き渡し時の手戻りをゼロにする</div>
    </div>
</div>

<!-- スライド6: UI統合の最終チェック5ポイント -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">UI統合の最終チェック：5つの確認ポイント</h2>
    <div class="content-block">
        <p>最適化の前に、Figma上でUI統合の品質を確定させる。最適化後に「この画像を差し替えたい」となると二度手間になる。</p>
        <table class="slide-table">
            <thead>
                <tr>
                    <th>チェック項目</th>
                    <th>確認内容</th>
                    <th>よくある問題</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>① エッジ</td>
                    <td>背景除去した画像の境界線</td>
                    <td>ハロー（白い縁取り）が残っている</td>
                </tr>
                <tr>
                    <td>② オーバーレイ</td>
                    <td>テキスト下の画像との馴染み</td>
                    <td>透明度が高すぎて画像が見えない / 低すぎてテキストが読めない</td>
                </tr>
                <tr>
                    <td>③ トーン統一</td>
                    <td>スクロールして通しで確認</td>
                    <td>画像間のトーンジャンプ（色温度・彩度の急変）</td>
                </tr>
                <tr>
                    <td>④ SP表示</td>
                    <td>SP版でのサイズと重さ</td>
                    <td>はみ出し・読み込みが重くなりそうなサイズ</td>
                </tr>
                <tr>
                    <td>⑤ alt属性</td>
                    <td>各画像の内容を1文で説明</td>
                    <td>空欄のまま → アクセシビリティ・SEO違反</td>
                </tr>
            </tbody>
        </table>
        <p class="text-note">※ alt属性のテキストは実装時にエンジニアが使用する。今から準備しておくことでハンドオフ時の手戻りを防ぐ</p>
    </div>
</div>

<!-- スライド7: 最適化チェックリスト -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">最適化チェックリスト（実践編で使用）</h2>
    <div class="content-block">
        <p>実践編では、TALENTBOARD用の各画像（LP用5枚＋バナー群＋CTAまわり）に対してこのチェックリストを使って確認する。</p>
        <table class="slide-table">
            <thead>
                <tr>
                    <th>確認項目</th>
                    <th>基準</th>
                    <th>目安サイズ</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>📄 フォーマット</td>
                    <td>WebPに変換済みか？（透過 → WebP/PNG）</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>🗜️ 圧縮品質</td>
                    <td>品質80%で目視劣化なし？</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>📐 解像度</td>
                    <td>PC 1440px / SP 750px 以内？</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>⚡ ファイルサイズ</td>
                    <td>FV 200KB以下 / セクション 150KB以下 / バナー 100KB以下</td>
                    <td>目安を参考に判断</td>
                </tr>
                <tr>
                    <td>🏷️ 命名規則</td>
                    <td>「セクション名_用途_幅.webp」で統一されているか？</td>
                    <td>—</td>
                </tr>
                <tr>
                    <td>📁 フォルダ分類</td>
                    <td>lp / banner / common に正しく配置されているか？</td>
                    <td>—</td>
                </tr>
            </tbody>
        </table>
        <div class="highlight-box">💡 このチェックリストを全画像でクリアできた状態が「パフォーマンス品質・管理品質が整った」状態。これがエンジニアに渡せる最低ラインだ</div>
    </div>
</div>

<!-- スライド8: 実践編の予告と準備 -->
<div class="slide-container standard-content-layout">
    <h2 class="slide-title">実践編の予告と事前準備</h2>
    <div class="content-block">
        <p>次のコマから実践編に入る。3つの演習でTALENTBOARDの全画像を「エンジニアに渡せる状態」に仕上げる。</p>
        <div class="content-block svg-centered">
            <svg viewBox="0 0 860 160" xmlns="http://www.w3.org/2000/svg" style="max-width:860px;width:100%;">
                <!-- 演習1 -->
                <rect x="10" y="20" width="240" height="120" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="130" y="55" text-anchor="middle" fill="#00d4ff" font-size="22" font-weight="bold">演習 1</text>
                <text x="130" y="82" text-anchor="middle" fill="white" font-size="17">LP用画像の最適化</text>
                <text x="130" y="106" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="15">5枚 × チェックリスト適用</text>
                <text x="130" y="128" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="14">（1.5コマ）</text>
                <!-- 矢印 -->
                <polygon points="258,80 278,70 278,90" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="250" y1="80" x2="278" y2="80" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- 演習2 -->
                <rect x="285" y="20" width="290" height="120" rx="12" fill="white" fill-opacity="0.08"/>
                <text x="430" y="55" text-anchor="middle" fill="#00d4ff" font-size="22" font-weight="bold">演習 2</text>
                <text x="430" y="82" text-anchor="middle" fill="white" font-size="17">バナー画像の最適化</text>
                <text x="430" y="106" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="15">＋ LP全体を通しで検証</text>
                <text x="430" y="128" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="14">（1コマ）</text>
                <!-- 矢印 -->
                <polygon points="583,80 603,70 603,90" fill="#00d4ff" fill-opacity="0.7"/>
                <line x1="575" y1="80" x2="603" y2="80" stroke="#00d4ff" stroke-opacity="0.7" stroke-width="2"/>

                <!-- 演習3 -->
                <rect x="610" y="20" width="240" height="120" rx="12" fill="#00d4ff" fill-opacity="0.13"/>
                <text x="730" y="55" text-anchor="middle" fill="#00d4ff" font-size="22" font-weight="bold">演習 3</text>
                <text x="730" y="82" text-anchor="middle" fill="white" font-size="17">029への引き渡し準備</text>
                <text x="730" y="106" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="15">フォルダ整理・命名確認</text>
                <text x="730" y="128" text-anchor="middle" fill="white" fill-opacity="0.55" font-size="14">（0.5コマ）</text>
            </svg>
        </div>
        <h3>今すぐ準備してください</h3>
        <ul>
            <li>🌐 <strong>Squoosh</strong>（squoosh.app）をブラウザで開いておく</li>
            <li>🎨 <strong>Figma</strong>の書き出し機能（右パネル下部「Export」）の場所を確認しておく</li>
            <li>📁 画像の保存先フォルダを作成しておく（images/lp/ / images/banner/）</li>
        </ul>
    </div>
</div>

<!-- スライド9: クイズへの誘導 -->
<div class="slide-container section-title-layout">
    <div class="section-title-content">
        <p class="section-label">理解度チェック</p>
        <h2>Quiz</h2>
        <p class="section-subtitle">画像最適化の判断軸を確認しよう</p>
    </div>
</div>

<script>
const quizData = [
    {
        question: "Q1. ページの表示速度が1秒遅くなると、CVR（コンバージョン率）はどう変化するか？",
        options: [
            "約2%下がる",
            "約7%下がる",
            "約15%下がる",
            "ほとんど影響しない"
        ],
        correct: 1,
        explanation: "表示速度が1秒遅れるとCVRは約7%低下するというデータがある。画像のファイルサイズはLP表示速度を最も左右する要素のひとつ。「軽くする」ことは見た目の問題ではなく、ビジネス成果に直結する判断だ。"
    },
    {
        question: "Q2. WebP形式がJPEGより優れている主な理由はどれか？",
        options: [
            "ファイルサイズが大きく、高画質を保てる",
            "同じ品質でJPEGより約30%軽量で、透過にも対応している",
            "すべてのデバイスで100%サポートされている唯一のフォーマット",
            "Figmaから直接書き出せる唯一のフォーマット"
        ],
        correct: 1,
        explanation: "WebPは同等の画質でJPEGより約30%軽量で、かつ透過（アルファチャンネル）にも対応している。現在の主要ブラウザはほぼすべてWebPをサポートしており、LPのメイン画像フォーマットとして推奨される。"
    },
    {
        question: "Q3. Squooshで圧縮品質を設定する際、推奨値として適切なのはどれか？",
        options: [
            "50%（できるだけ軽くする）",
            "70%（ある程度の劣化は許容する）",
            "80%（見た目の劣化なしに大幅削減できるスイートスポット）",
            "100%（無劣化を最優先する）"
        ],
        correct: 2,
        explanation: "品質80%が「見た目の劣化がほぼなく、ファイルサイズを大幅に削減できる」スイートスポット。70%以下は劣化が目視で確認できてしまうため非推奨。100%は無劣化だがファイルサイズが大きすぎる。"
    },
    {
        question: "Q4. Figmaから書き出すファイルの命名規則を統一する主な理由はどれか？",
        options: [
            "Figmaの書き出し機能が命名規則を要求するため",
            "Squooshがファイル名を読み取って自動変換するため",
            "エンジニアへのハンドオフ時に「どの画像がどこで使われるか」を迷わせないため",
            "WebPフォーマットが特定の命名規則を必要とするため"
        ],
        correct: 2,
        explanation: "Block 7（039・エンジニアへのハンドオフ）で実装者が「どの画像がどこで使われるか」をすぐに判断できるようにするため。命名がバラバラだと確認工数が増え、実装ミスのリスクも上がる。管理品質を整えることが、チームワークの効率に直結する。"
    },
    {
        question: "Q5. 画像最適化を行う「前」にUI統合の最終チェックを済ませる理由はどれか？",
        options: [
            "Squooshはチェック済みの画像しか処理できないため",
            "最適化後に画像を差し替えると二度手間になるため",
            "FigmaはチェックリストをクリアするまでExportできないため",
            "統合チェックとWebP変換を同時に行えないため"
        ],
        correct: 1,
        explanation: "最適化後に「やっぱりこの画像を変えたい」となると、再度Figmaで修正→書き出し→Squooshで変換→名前変更→フォルダ整理……という二度手間になる。統合品質（デザイン品質）を確定させてから最適化（パフォーマンス品質）に入る順序が正しい。"
    }
];

let currentQuiz = 0;
let score = 0;
let answered = false;

function initQuiz() {
    const quizSlide = document.querySelector('.quiz-slide');
    if (!quizSlide) return;
    renderQuiz();
}

function renderQuiz() {
    const container = document.getElementById('quiz-container');
    if (!container) return;

    const q = quizData[currentQuiz];
    answered = false;

    container.innerHTML = `
        <div class="quiz-progress">問題 ${currentQuiz + 1} / ${quizData.length}</div>
        <div class="quiz-question">${q.question}</div>
        <div class="quiz-options">
            ${q.options.map((opt, i) => `
                <button class="quiz-option" onclick="selectAnswer(${i})">${opt}</button>
            `).join('')}
        </div>
        <div class="quiz-feedback" id="quiz-feedback" style="display:none;"></div>
        <div class="quiz-nav" id="quiz-nav" style="display:none;">
            ${currentQuiz < quizData.length - 1
                ? `<button class="quiz-next-btn" onclick="nextQuestion()">次の問題へ →</button>`
                : `<button class="quiz-next-btn" onclick="showResult()">結果を見る</button>`
            }
        </div>
    `;
}

function selectAnswer(index) {
    if (answered) return;
    answered = true;

    const q = quizData[currentQuiz];
    const options = document.querySelectorAll('.quiz-option');
    const feedback = document.getElementById('quiz-feedback');
    const nav = document.getElementById('quiz-nav');

    options.forEach((opt, i) => {
        opt.disabled = true;
        if (i === q.correct) opt.classList.add('correct');
        else if (i === index) opt.classList.add('incorrect');
    });

    if (index === q.correct) {
        score++;
        feedback.innerHTML = `✅ 正解！${q.explanation}`;
        feedback.className = 'quiz-feedback correct-feedback';
    } else {
        feedback.innerHTML = `❌ 不正解。正解は「${q.options[q.correct]}」です。${q.explanation}`;
        feedback.className = 'quiz-feedback incorrect-feedback';
    }

    feedback.style.display = 'block';
    nav.style.display = 'block';
}

function nextQuestion() {
    currentQuiz++;
    renderQuiz();
}

function showResult() {
    const container = document.getElementById('quiz-container');
    container.innerHTML = `
        <div class="quiz-result">
            <h3>クイズ終了！</h3>
            <p class="quiz-score">${score} / ${quizData.length} 問正解</p>
            <p>${score === quizData.length ? '🎉 パーフェクト！画像最適化の判断軸を完全に理解しています。'
               : score >= 3 ? '👍 よくできました！間違えた問題の解説を復習しておきましょう。'
               : '📚 もう一度理論編の内容を確認してから再挑戦してみましょう。'}</p>
            <button class="quiz-next-btn" onclick="resetQuiz()">もう一度挑戦する</button>
        </div>
    `;
}

function resetQuiz() {
    currentQuiz = 0;
    score = 0;
    renderQuiz();
}

document.addEventListener('DOMContentLoaded', initQuiz);
</script>
